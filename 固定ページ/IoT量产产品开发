						<th>天线</th>
						<td>内置天线（蜂窝通信/卫星定位）
						</td>
					</tr>
					<tr>
						<th>通信接口</th>
						<td>CAN、K-LINE、UART</td>
					</tr>
					<tr>
						<th>认证</th>
						<td>CE（欧盟）、UKCA（英国）、FCC（美国）、JATE/TELEC（日本）</td>
					</tr>
				</tbody>
			</table>

				
			</div>
		</div>
	</section>
</div>
